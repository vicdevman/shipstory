# MongoDB Connection (Shared with python agents)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/shipstory

# Connie Chat Connection Fallsback (Mandatory on Vercel deployment if local agents are cold starting)
BAND_ROOM_ID=your_band_room_uuid_here
CONNIE_AGENT_ID=your_connie_agent_uuid_here
DEVIN_API_KEY=band_a_your_devin_agent_api_key_here
BAND_REST_URL=https://app.band.ai/

# GitHub Token (Optional — used by webhooks to query code patches/diffs from private/rate-limited repos)
GITHUB_TOKEN=ghp_your_personal_access_token_here

