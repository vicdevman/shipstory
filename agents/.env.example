# Python API Keys & Tokens for Band Platform
# Copy this file to .env and populate it with your own secret keys.

# Band.ai Platform WebSocket credentials
BAND_API_KEY=your_band_api_key_here

# Band URLs
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Cold-start fallback room ID (mandatory if starting Connie/Pipeline before first Band webhook runs)
BAND_ROOM_ID=your_band_room_uuid_here

# LLM API Keys - Fill keys for the provider(s) you use
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AIML API Settings (Provides GPT/Claude/Flux image models)
AIML_API_KEY=your_aiml_api_key_here
AIML_API_BASE=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# Featherless Settings (Provides fast Llama 3.1 inference)
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_API_BASE=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Groq Settings (Alternative model provider)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Agent-specific LLM Provider selections
# Supported values: "aiml" | "featherless" | "groq" | "openai" | "anthropic"
DEVIN_PROVIDER=groq
PRISCILLA_PROVIDER=aiml
GIGI_PROVIDER=featherless
CONNIE_PROVIDER=aiml
MARSHALL_PROVIDER=groq
VINCI_PROVIDER=aiml

# Central MongoDB Instance (Shared with Next.js webapp)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/shipstory

# Tavily AI Search Key (for Marshall competitor scans)
TAVILY_API_KEY=your_tavily_key_here

# GitHub Token (Optional — used by webhook/explorers to fetch diffs from private/rate-limited repos)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Cloudinary credentials (for hosting Gigi's visuals generated by Vinci/Flux)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=shipstory
